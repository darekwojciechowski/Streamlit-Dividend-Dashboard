# Dividend Dashboard — environment configuration template
# Copy this file to .env and fill in values for your environment.
# The .env file is gitignored and must never be committed.

# ---------------------------------------------------------------------------
# Data
# ---------------------------------------------------------------------------
# Path to the TSV dividend portfolio data file.
# Default: data/dividend_data.csv
# DATA_FILE_PATH=data/dividend_data.csv

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------
# Deployment environment: local | staging | production
# Default: local
# ENVIRONMENT=local

# Enable debug mode (extra logging, exception details).
# Default: false
# DEBUG=false
